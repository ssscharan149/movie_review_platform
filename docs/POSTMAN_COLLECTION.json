{
  "info": {
    "name": "Movie Review Platform API",
    "_postman_id": "9d3888a3-6a5d-4d85-a2cf-3b5d38f0e071",
    "description": "Postman collection for the Movie Review Platform backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "movieId", "value": "1" },
    { "key": "genreId", "value": "1" },
    { "key": "reviewId", "value": "1" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"Password@123\",\n  \"role\": \"ADMIN\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.collectionVariables.set('accessToken', json.token);",
                  "if (json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.collectionVariables.set('accessToken', json.token);",
                  "if (json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/refresh"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.collectionVariables.set('accessToken', json.token);",
                  "if (json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Genres (Admin)",
      "item": [
        {
          "name": "Create Genre",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sci-Fi\"\n}"
            },
            "url": "{{baseUrl}}/genres"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) pm.collectionVariables.set('genreId', json.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "List Genres (Public)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/genres"
          }
        },
        {
          "name": "Update Genre",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Science Fiction\"\n}"
            },
            "url": "{{baseUrl}}/genres/{{genreId}}"
          }
        },
        {
          "name": "Delete Genre",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/genres/{{genreId}}"
          }
        }
      ]
    },
    {
      "name": "Movies",
      "item": [
        {
          "name": "Create Movie (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Interstellar\",\n  \"description\": \"A sci-fi movie about space exploration and survival that pushes humanity to new frontiers.\",\n  \"releaseYear\": 2014,\n  \"posterUrl\": \"https://example.com/interstellar.jpg\",\n  \"trailerUrl\": \"https://www.youtube.com/watch?v=zSWdZVtXT7E\",\n  \"genreIds\": [{{genreId}}]\n}"
            },
            "url": "{{baseUrl}}/movies"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) pm.collectionVariables.set('movieId', json.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "List Movies (Public)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/movies?page=0&size=10"
          }
        },
        {
          "name": "Get Movie By Id (Public)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/movies/{{movieId}}"
          }
        },
        {
          "name": "Update Movie (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Interstellar (Updated)\",\n  \"description\": \"Updated description for interstellar movie record with enough detail for validation.\",\n  \"releaseYear\": 2014,\n  \"posterUrl\": \"https://example.com/interstellar-updated.jpg\",\n  \"trailerUrl\": \"https://www.youtube.com/watch?v=zSWdZVtXT7E\",\n  \"genreIds\": [{{genreId}}]\n}"
            },
            "url": "{{baseUrl}}/movies/{{movieId}}"
          }
        },
        {
          "name": "Delete Movie (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/movies/{{movieId}}"
          }
        }
      ]
    },
    {
      "name": "Ratings and Reviews",
      "item": [
        {
          "name": "Submit Rating",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"score\": 5\n}"
            },
            "url": "{{baseUrl}}/movies/{{movieId}}/rating"
          }
        },
        {
          "name": "Delete My Rating",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/movies/{{movieId}}/rating"
          }
        },
        {
          "name": "Get Rating Summary (Public)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/movies/{{movieId}}/rating-summary"
          }
        },
        {
          "name": "Create Review",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"This is a detailed review content with enough text to satisfy validation constraints.\"\n}"
            },
            "url": "{{baseUrl}}/movies/{{movieId}}/reviews"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) pm.collectionVariables.set('reviewId', json.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "List Movie Reviews (Public)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/movies/{{movieId}}/reviews?page=0&size=10"
          }
        },
        {
          "name": "Update My Review",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Updated review content that still satisfies minimum validation length.\"\n}"
            },
            "url": "{{baseUrl}}/reviews/{{reviewId}}"
          }
        },
        {
          "name": "Delete Review",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/reviews/{{reviewId}}"
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Hello Endpoint",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/hello"
          }
        }
      ]
    }
  ]
}

