# Use strong, unique credentials in production.
# Do not commit real secrets.

# Database
MYSQL_ROOT_PASSWORD=change_me_root_password
APP_DB_USER=movie_app
APP_DB_PASSWORD=change_me_app_password

# JWT (Base64-encoded key, 256-bit+)
JWT_SECRET=replace_with_strong_base64_secret
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=172800000

# CORS (comma-separated production origins only)
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# Frontend (if self-hosting frontend build with Docker)
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

